# Fully local (no Supabase Postgres): default `npm run dev` sets LOCAL_DEV_MODE; or set it here manually.
# Uses backend/local.db (SQLite). DATABASE_URL is ignored while LOCAL_DEV_MODE is true.
# LOCAL_DEV_MODE=true
# LOCAL_SQLITE_PATH=./local.db
#
# Local pipeline without Replicate billing (npm run dev sets this automatically):
# LOCAL_DEV_SKIP_UPSCALE=true   → enhancement only (OpenAI/Gemini); no r8_ token required.
# LOCAL_DEV_SKIP_UPSCALE=false  → full pipeline; needs Replicate credit or use fallback below.
# If you use Replicate but hit HTTP 402, this still completes with the enhanced image:
# LOCAL_DEV_UPSCALE_FALLBACK_ON_CREDIT_ERROR=true
#
# Optional: lock local login to one email/password (otherwise any non-empty email/password works in dev).
# LOCAL_DEV_LOGIN_EMAIL=you@example.com
# LOCAL_DEV_LOGIN_PASSWORD=choose-a-dev-password

# Application
APP_ENV=development
# Logging: DEBUG (default in development), INFO, WARNING, ERROR — also sets uvicorn --log-level
# LOG_LEVEL=DEBUG
APP_SECRET_KEY=change-me-to-random-64-char-hex
API_KEY_ENCRYPTION_KEY=change-me-generate-with-fernet

# Supabase (same project as the frontend; secret key server-only, never in Vite)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_SECRET_KEY=sb_secret_...
SUPABASE_JWT_SECRET=your-jwt-secret-from-supabase-dashboard-auth-settings

# Database — copy URI from Supabase → Project Settings → Database (use "Transaction" pooler for the API).
# Use the async form below. URL-encode special characters in the password (@ → %40, # → %23, etc.).
# DATABASE_SSL_REQUIRE: omit for auto (TLS on when host contains "supabase"), or true / false.
DATABASE_URL=postgresql+asyncpg://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres
# DATABASE_SSL_REQUIRE=true
#
# SQL hardening (RLS, api_keys): new projects run backend/supabase_setup.sql in the Supabase SQL Editor.
# Existing projects run backend/supabase_migrations/003_secure_rls_authenticated.sql once (includes api_keys lockdown).

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET_KEY=change-me-to-random-64-char-hex
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Upload — use ./uploads (resolved under backend/). Writable on THIS machine only; never copy an
# absolute path from another user or computer (e.g. /Users/someoneelse/...).
MAX_UPLOAD_SIZE_MB=50
# Must match frontend workspace batch cap (bulk import).
MAX_FILES_PER_UPLOAD_BATCH=25
UPLOAD_DIR=./uploads
# Reference list; API validates with Pillow decode. Add formats as you enable plugins (e.g. pillow-heif).
ALLOWED_EXTENSIONS=jpg,jpeg,jpe,png,webp,tiff,tif,gif,bmp,ico,avif,heic,heif,jxl,svg,psd,jp2,j2k,cr2,nef,arw,dng
# Optional: read chunk size for streaming uploads (default 8 MiB).
# UPLOAD_READ_CHUNK_BYTES=8388608
#
# Privacy: when false, image bytes are deleted from disk after each job (pixels are never stored in the DB).
# Metadata rows remain. Latest result file is kept for EPHEMERAL_IMAGE_GRACE_SECONDS so the browser can download it.
# PERSIST_IMAGE_FILES_ON_SERVER=true
# EPHEMERAL_IMAGE_GRACE_SECONDS=180
#
# Multi-tenant isolation: all tables are keyed by user_id from the JWT; only use one shared Postgres database with RLS
# (see backend/supabase_setup.sql and migrations) — not a separate physical database per end user.

# CORS
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:2020,http://127.0.0.1:2020,http://localhost:8989,http://127.0.0.1:8989,http://localhost:3000,http://127.0.0.1:3000
