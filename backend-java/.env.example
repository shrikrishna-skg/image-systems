# Copy to backend-java/.env (never commit real values). Maps to application.yml / AppProperties.

APP_ENV=development
APP_SECRET_KEY=change-me-to-random-64-char-hex
# Fernet (44 url-safe chars) — same format as Python backend for encrypted api_keys rows.
API_KEY_ENCRYPTION_KEY=

LOCAL_DEV_MODE=true
LOCAL_DEV_SKIP_UPSCALE=true
# LOCAL_DEV_LOGIN_EMAIL=
# LOCAL_DEV_LOGIN_PASSWORD=

SUPABASE_JWT_SECRET=

# Default dev: H2 file DB. For Postgres + Flyway: SPRING_PROFILES_ACTIVE=postgres
# DATABASE_URL=jdbc:postgresql://localhost:5432/imagesystems
# DATABASE_USERNAME=postgres
# DATABASE_PASSWORD=postgres

UPLOAD_DIR=./uploads
PORT=8000

# Optional: comma-separated extra origins (merged with application.yml list)
# CORS_ORIGINS=https://your-app.vercel.app

# Profiles: development (default), staging, production, postgres
# SPRING_PROFILES_ACTIVE=production,postgres

# Hikari (optional overrides)
# HIKARI_MAX_POOL_SIZE=20

# Logging
# LOG_LEVEL_IMAGESYSTEMS=INFO

# Optional: Zyte for scrape
# ZYTE_API_KEY=
