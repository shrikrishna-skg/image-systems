# Loaded automatically by Vite in development (npm run dev).
# Full stack + local SQLite auth: use repo root `npm run dev` (starts API with LOCAL_DEV_MODE).
#
# Override in .env.development.local (gitignored): e.g. VITE_USE_API=false + VITE_STORAGE_ONLY=true for browser-only.

VITE_USE_API=true
VITE_STORAGE_ONLY=false
VITE_LOCAL_DEV_MODE=true
VITE_API_BASE_URL=/api
VITE_VERBOSE_API_LOGS=true
