# Development defaults live in frontend/.env.development (API + local JWT via Vite proxy).
# Copy this file to frontend/.env for production builds or Supabase-only dev (see npm run dev:supabase).
#
# --- Vercel (Production / Preview) ---
# Add these in: Project → Settings → Environment Variables, then Redeploy.
# Vite bakes VITE_* in at build time — they must exist before "npm run build" on Vercel.
#
#   VITE_SUPABASE_URL=https://YOUR_REF.supabase.co
#   VITE_SUPABASE_ANON_KEY=your_anon_public_key
#   VITE_API_BASE_URL=https://your-api-host.example.com/api
# Optional: VITE_VERBOSE_API_LOGS=true (usually off in prod)
#
# Password reset emails: Supabase → Authentication → URL Configuration → add
#   https://YOUR_VERCEL_APP.vercel.app/login
# to Redirect URLs (and set Site URL to the same origin).
#
# Browser-only override: create frontend/.env.development.local (gitignored) with:
#   VITE_USE_API=false
#   VITE_STORAGE_ONLY=true
#   VITE_LOCAL_DEV_MODE=true

VITE_API_BASE_URL=/api
# VITE_USE_API=true
# VITE_STORAGE_ONLY=false
# Log API calls in the browser console (npm run dev sets this to true).
# VITE_VERBOSE_API_LOGS=true
# VITE_LOCAL_DEV_MODE=true
# VITE_API_BASE_URL=http://127.0.0.1:8000/api

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_publishable_or_anon_key
