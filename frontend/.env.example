# Development defaults live in frontend/.env.development (API + local JWT via Vite proxy).
# Copy this file to frontend/.env for production builds or Supabase-only dev (see npm run dev:supabase).
#
# --- Vercel (Production / Preview) ---
# Add these in: Project → Settings → Environment Variables, then Redeploy.
# Vite bakes VITE_* in at build time — they must exist before "npm run build" on Vercel.
#
#   VITE_SUPABASE_URL=https://YOUR_REF.supabase.co
#   VITE_SUPABASE_ANON_KEY=your_anon_public_key
#   VITE_API_BASE_URL=https://your-api-host.example.com/api
# Optional: VITE_VERBOSE_API_LOGS=true (usually off in prod)
#
# Email confirmation & password reset links must match an allowed URL in Supabase:
# Authentication → URL Configuration:
#   Site URL: https://YOUR_VERCEL_APP.vercel.app  (your real production origin, not localhost)
#   Redirect URLs: add https://YOUR_VERCEL_APP.vercel.app/login (and http://localhost:* /login for local dev)
#
# If you sign up from localhost but want the email link to open Vercel, set:
#   VITE_AUTH_REDIRECT_ORIGIN=https://YOUR_VERCEL_APP.vercel.app
# (Also add that /login URL to Supabase Redirect URLs.)
#
# Browser-only override: create frontend/.env.development.local (gitignored) with:
#   VITE_USE_API=false
#   VITE_STORAGE_ONLY=true
#   VITE_LOCAL_DEV_MODE=true

VITE_API_BASE_URL=/api
# VITE_USE_API=true
# VITE_STORAGE_ONLY=false
# Log API calls in the browser console (npm run dev sets this to true).
# VITE_VERBOSE_API_LOGS=true
# Axios timeout for large uploads (ms). Default in client is 600000 (10m).
# VITE_API_TIMEOUT_MS=600000
# Optional: workspace queue hard cap (default 9999). Integer 1–50000.
# VITE_MAX_WORKSPACE_ASSETS=200
# Workspace batch (OpenAI/Gemini/Replicate pipeline): parallel process calls, default 4, max 12.
# VITE_BATCH_PIPELINE_CONCURRENCY=4
# VITE_LOCAL_DEV_MODE=true
# VITE_API_BASE_URL=http://127.0.0.1:8000/api

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_publishable_or_anon_key
