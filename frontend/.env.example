# In development, browser-only (IndexedDB) is the default — no Python server.
# To use the FastAPI backend from the frontend folder:
#   VITE_USE_API=true
#   VITE_API_BASE_URL=http://127.0.0.1:8000/api
# Or run from repo root: npm run dev:full

VITE_API_BASE_URL=/api
# VITE_USE_API=true
# VITE_STORAGE_ONLY=false
# Log API calls in the browser console (npm run dev sets this to true).
# VITE_VERBOSE_API_LOGS=true
# VITE_LOCAL_DEV_MODE=true
# VITE_API_BASE_URL=http://127.0.0.1:8000/api

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_publishable_or_anon_key
